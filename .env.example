# ============================================================
# SP Pickleball — Environment Variables
# Copy this file to .env.local and fill in all values
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sp_pickleball?schema=public"
# Recommended: use Neon, Supabase, or Railway for serverless-compatible PostgreSQL
# e.g. DATABASE_URL="postgresql://neondb_owner:xxx@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- NextAuth / Auth.js ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-at-least-32-chars"   # openssl rand -base64 32

# --- Google OAuth (for member login) ---
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://sportspoint.tw"
NEXT_PUBLIC_SITE_NAME="SP Pickleball"
NEXT_PUBLIC_SITE_DESCRIPTION="台灣最完整的匹克球拍購物、評測與教學平台"

# --- Media / Image Upload ---
# Option A: Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Option B: Uploadthing (simpler for Next.js)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# --- Analytics (all optional, frontend-only) ---
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
NEXT_PUBLIC_CLARITY_PROJECT_ID=""
NEXT_PUBLIC_GSC_SITE_URL="https://sportspoint.tw"

# --- Google Merchant Center ---
GOOGLE_MERCHANT_ID=""

# --- LINE Notify / LINE Bot (for order notifications) ---
LINE_NOTIFY_TOKEN=""
LINE_BOT_CHANNEL_ACCESS_TOKEN=""
LINE_BOT_CHANNEL_SECRET=""

# --- Admin ---
ADMIN_EMAIL="admin@sportspoint.tw"

# --- Email (for order confirmations) ---
# Option: Resend, SendGrid, Nodemailer
RESEND_API_KEY=""
EMAIL_FROM="noreply@sportspoint.tw"

# --- Cron Secret (for scheduled jobs) ---
CRON_SECRET="your-cron-secret"
