// SP Pickleball — Prisma Schema
// PostgreSQL + Prisma ORM

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  OWNER
  ADMIN
  SEO_EDITOR
  CONTENT_EDITOR
  CUSTOMER_SERVICE
  WAREHOUSE
  VIEWER
  CUSTOMER
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SuitableFor {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  TENNIS_CONVERT
  FEMALE
  DOUBLES
  SINGLES
}

enum OrderStatus {
  PENDING_PAYMENT
  TRANSFER_NOTIFIED
  PENDING_CONFIRM
  PREPARING
  SHIPPED
  COMPLETED
  CANCELLED
  RETURNING
  REFUNDED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum ShippingMethod {
  POST_OFFICE
  SEVEN_ELEVEN
  FAMILY_MART
  HOME_DELIVERY
}

// ============================================================
// AUTH (NextAuth / Auth.js compatible)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  reviews       Review[]
  articles      Article[]
  wishlistItems WishlistItem[]
  addresses     Address[]
  auditLogs     AuditLog[]
  compareItems  CompareItem[]
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  name       String
  phone      String
  address    String
  city       String
  district   String
  postalCode String
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ============================================================
// PRODUCT SYSTEM
// ============================================================

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  logo        String?
  coverImage  String?
  description String?  @db.Text
  history     String?  @db.Text
  techFeatures String? @db.Text
  website     String?
  country     String?
  foundedYear Int?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  image       String?
  parentId    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  sku         String        @unique
  brandId     String
  categoryId  String
  price       Decimal       @db.Decimal(10, 2)
  salePrice   Decimal?      @db.Decimal(10, 2)
  stock       Int           @default(0)
  status      ProductStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)

  // Physical specs
  weight              Float?  // grams
  thickness           Float?  // mm
  length              Float?  // mm
  width               Float?  // mm
  gripLength          Float?  // mm
  gripCircumference   Float?  // mm

  // Materials
  material          String?
  coreMaterial      String?
  surfaceMaterial   String?
  certification     String?

  // Scores (0-100)
  controlScore     Int?
  powerScore       Int?
  spinScore        Int?
  forgivenessScore Int?
  feelScore        Int?

  // Suitability
  suitableFor SuitableFor[]

  // Media
  mainImage  String?
  gallery    String[]
  youtubeUrl String?
  reelsUrl   String?

  // Content
  description   String? @db.Text
  specs         Json?   // flexible key-value specs
  faq           Json?   // array of {question, answer}

  // GTIN / MPN for Merchant Center
  gtin String?
  mpn  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand    Brand    @relation(fields: [brandId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  orderItems     OrderItem[]
  reviews        Review[]
  wishlistItems  WishlistItem[]
  compareItems   CompareItem[]
  cartItems      CartItem[]

  // Self-referential relations for recommendations
  relatedProducts     Product[] @relation("RelatedProducts")
  relatedProductsOf   Product[] @relation("RelatedProducts")
  similarPaddles      Product[] @relation("SimilarPaddles")
  similarPaddlesOf    Product[] @relation("SimilarPaddles")
  upgradeFrom         Product[] @relation("UpgradeRecommendations")
  upgradeTo           Product[] @relation("UpgradeRecommendations")

  // Article links
  relatedArticles Article[] @relation("ProductArticles")
}

// ============================================================
// CONTENT
// ============================================================

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?       @db.Text
  content     String        @db.Text
  coverImage  String?
  authorId    String?
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  tags        String[]
  readingTime Int?          // minutes
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author   User?     @relation(fields: [authorId], references: [id])  // Note: Add User relation

  relatedProducts Product[] @relation("ProductArticles")
}

// Fix: Article needs authorId field referencing User
// Already included above

model FAQ {
  id         String   @id @default(cuid())
  question   String
  answer     String   @db.Text
  category   String?  // e.g. "shipping", "product", "academy"
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pageFaqs FaqPageItem[]
}

model FaqPage {
  id          String   @id @default(cuid())
  slug        String   @unique   // e.g. "general", "shipping", "products"
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items    FaqPageItem[]
}

model FaqPageItem {
  id        String   @id @default(cuid())
  faqPageId String
  faqId     String
  sortOrder Int      @default(0)

  faqPage FaqPage @relation(fields: [faqPageId], references: [id], onDelete: Cascade)
  faq     FAQ     @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqPageId, faqId])
}

// ============================================================
// COMPARE PAGES
// ============================================================

model ComparePage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  productIds  String[] // array of product IDs being compared
  isIndexed   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

}

// ============================================================
// AI ADVISOR PAGES
// ============================================================

model AiPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  content     String?  @db.Text
  pageType    String   @default("guide") // "guide" | "comparison" | "faq"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

}

// ============================================================
// SEO & GEO
// ============================================================

model SeoMeta {
  id              String   @id @default(cuid())
  entityType      String   // "product" | "brand" | "category" | "article" | "faq_page" | "compare" | "ai_page"
  entityId        String   @unique

  title           String?
  description     String?
  canonical       String?
  ogImage         String?
  ogTitle         String?
  ogDescription   String?
  twitterCard     String?  @default("summary_large_image")
  twitterTitle    String?
  twitterDescription String?
  noIndex         Boolean  @default(false)
  noFollow        Boolean  @default(false)
  inSitemap       Boolean  @default(true)
  breadcrumbTitle String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Polymorphic back-relations (only one will be non-null)
}

model GeoContent {
  id               String   @id @default(cuid())
  entityType       String
  entityId         String   @unique

  aiSummary        String?  @db.Text
  aiFaq            Json?    // array of {question, answer}
  aiStructuredContent Json?
  aiQuickAnswer    String?  @db.Text
  recommendations  Json?    // array of product/article refs
  pros             String[] // advantages
  cons             String[] // disadvantages
  suitableFor      String[] // audience tags
  notSuitableFor   String[]
  lastReviewed     DateTime?
  authorName       String?
  reviewerName     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-relations
}

// Global SEO settings (for pages without entity)
model GlobalSeo {
  id             String   @id @default(cuid())
  pageType       String   @unique // "home" | "products" | "cart" | "checkout" | "account" | etc.
  title          String?
  description    String?
  ogImage        String?
  noIndex        Boolean  @default(false)
  inSitemap      Boolean  @default(true)
  updatedAt      DateTime @updatedAt
}

// ============================================================
// ECOMMERCE
// ============================================================

model Cart {
  id        String     @id @default(cuid())
  sessionId String?    @unique
  userId    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @default(cuid())
  userId          String?
  addressId       String?
  status          OrderStatus @default(PENDING_PAYMENT)
  shippingMethod  ShippingMethod @default(HOME_DELIVERY)
  cvstoreId       String?     // convenience store ID
  cvstoreName     String?
  subtotal        Decimal     @db.Decimal(10, 2)
  shippingFee     Decimal     @db.Decimal(10, 2) @default(0)
  total           Decimal     @db.Decimal(10, 2)
  note            String?     @db.Text
  // Transfer info
  transferBank    String?
  transferAccount String?
  transferAmount  Decimal?    @db.Decimal(10, 2)
  transferNotifiedAt DateTime?
  // Shipping
  trackingNumber  String?
  shippedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  // Contact (denormalized for record-keeping)
  buyerName       String
  buyerEmail      String
  buyerPhone      String
  shippingAddress String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User?     @relation(fields: [userId], references: [id])
  address Address?  @relation(fields: [addressId], references: [id])
  items   OrderItem[]
  statusHistory OrderStatusHistory[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdBy String?     // userId or "system"
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model CompareItem {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  productId String
  createdAt DateTime @default(now())

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  authorName String
  rating    Int      // 1-5
  title     String?
  content   String   @db.Text
  isVerified Boolean @default(false)
  isPublished Boolean @default(false)
  helpfulCount Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
}

// ============================================================
// MEDIA
// ============================================================

model Media {
  id          String    @id @default(cuid())
  filename    String
  originalName String
  url         String
  thumbnailUrl String?
  mimeType    String
  size        Int       // bytes
  width       Int?
  height      Int?
  alt         String?
  type        MediaType @default(IMAGE)
  uploadedBy  String?
  createdAt   DateTime  @default(now())
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // CREATE | UPDATE | DELETE | LOGIN | etc.
  entityType  String?  // "Product" | "Order" | etc.
  entityId    String?
  oldData     Json?
  newData     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ============================================================
// SITE SETTINGS
// ============================================================

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string") // "string" | "json" | "boolean" | "number"
  group     String?  // "general" | "shipping" | "payment" | "social" | etc.
  label     String?
  updatedAt DateTime @updatedAt
}

// ============================================================
// ACADEMY
// ============================================================

model Coach {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  title       String?
  bio         String?  @db.Text
  image       String?
  certifications String[]
  specialties String[]
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[]
}

model Course {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  coachId     String?
  description String?  @db.Text
  level       String?  // "beginner" | "intermediate" | "advanced"
  price       Decimal? @db.Decimal(10, 2)
  duration    String?  // e.g. "8 weeks"
  maxStudents Int?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coach Coach? @relation(fields: [coachId], references: [id])
}

model Venue {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  address     String?
  city        String?
  district    String?
  description String?  @db.Text
  image       String?
  lat         Float?
  lng         Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// NOTIFICATIONS (缺貨 / 到貨)
// ============================================================

model StockNotification {
  id        String   @id @default(cuid())
  productId String
  email     String
  phone     String?
  type      String   @default("restock") // "restock" | "new_arrival"
  notified  Boolean  @default(false)
  notifiedAt DateTime?
  createdAt DateTime @default(now())
}
